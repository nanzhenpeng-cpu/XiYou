<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>西柚数据清洗打标工具 - 操作指南</title>
    <style>
        :root {
            --sidebar-width: 290px;
            --sidebar-bg: #0f172a;
            --sidebar-text: #94a3b8;
            --sidebar-hover-bg: #1e293b;
            --sidebar-hover-text: #e2e8f0;
            --sidebar-active-bg: #1e3a5f;
            --sidebar-active-border: #3b82f6;
            --sidebar-active-text: #ffffff;
            --accent: #3b82f6;
            --accent-soft: #eff6ff;
            --text-heading: #0f172a;
            --text-body: #334155;
            --text-muted: #64748b;
            --bg-page: #f8fafc;
            --bg-surface: #ffffff;
            --border: #e2e8f0;
            --border-light: #f1f5f9;
            --case-bg: #f0f7ff;
            --case-border: #3b82f6;
            --tip-bg: #fffbeb;
            --tip-border: #f59e0b;
            --success-bg: #f0fdf4;
            --success-text: #16a34a;
            --error-bg: #fef2f2;
            --error-text: #dc2626;
            --code-bg: #f1f5f9;
            --code-text: #e11d48;
            --shadow-xs: 0 1px 2px rgba(0, 0, 0, 0.04);
            --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.06);
            --shadow-md: 0 4px 12px rgba(0, 0, 0, 0.08);
            --shadow-lg: 0 12px 32px rgba(0, 0, 0, 0.12);
            --radius-sm: 6px;
            --radius: 8px;
            --radius-lg: 12px;
            --transition: 0.25s cubic-bezier(0.4, 0, 0.2, 1);
            --font-mono: 'SF Mono', 'Fira Code', 'Consolas', 'Monaco', 'Courier New', monospace;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        html {
            scroll-behavior: smooth;
            scroll-padding-top: 76px;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
            background: var(--bg-page);
            color: var(--text-body);
            line-height: 1.78;
            display: flex;
            min-height: 100vh;
            -webkit-font-smoothing: antialiased;
            -moz-osx-font-smoothing: grayscale;
        }

        /* ==================== 侧边栏 ==================== */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            width: var(--sidebar-width);
            height: 100vh;
            background: var(--sidebar-bg);
            color: var(--sidebar-text);
            z-index: 1000;
            display: flex;
            flex-direction: column;
            transition: transform var(--transition);
            box-shadow: var(--shadow-lg);
            will-change: transform;
        }

        .sidebar.collapsed {
            transform: translateX(calc(-1 * var(--sidebar-width)));
        }

        /* 侧边栏头部 */
        .sidebar-header {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 16px 14px 18px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.08);
            flex-shrink: 0;
        }
        .sidebar-brand {
            display: flex;
            align-items: center;
            gap: 10px;
            font-weight: 700;
            font-size: 15px;
            color: #fff;
            white-space: nowrap;
            letter-spacing: -0.01em;
        }
        .sidebar-brand .brand-dot {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: var(--accent);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 15px;
            flex-shrink: 0;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.25);
        }
        .sidebar-close-btn {
            display: none;
            background: none;
            border: none;
            color: #64748b;
            font-size: 20px;
            cursor: pointer;
            padding: 4px 8px;
            border-radius: var(--radius-sm);
            transition: all var(--transition);
            line-height: 1;
        }
        .sidebar-close-btn:hover {
            color: #fff;
            background: rgba(255, 255, 255, 0.08);
        }

        /* 导航滚动区 */
        .sidebar-nav {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 6px 0 24px 0;
            scrollbar-width: thin;
            scrollbar-color: rgba(255, 255, 255, 0.12) transparent;
        }
        .sidebar-nav::-webkit-scrollbar {
            width: 4px;
        }
        .sidebar-nav::-webkit-scrollbar-track {
            background: transparent;
        }
        .sidebar-nav::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, 0.18);
            border-radius: 10px;
        }

        .nav-list {
            list-style: none;
            margin: 0;
            padding: 0;
        }

        .nav-link {
            display: flex;
            align-items: center;
            gap: 7px;
            padding: 9px 18px;
            cursor: pointer;
            color: var(--sidebar-text);
            text-decoration: none;
            font-size: 13.5px;
            transition: all var(--transition);
            border-left: 3px solid transparent;
            white-space: nowrap;
            user-select: none;
            letter-spacing: 0.01em;
        }
        .nav-link:hover {
            background: var(--sidebar-hover-bg);
            color: var(--sidebar-hover-text);
        }
        .nav-link.active {
            background: var(--sidebar-active-bg);
            color: var(--sidebar-active-text);
            border-left-color: var(--sidebar-active-border);
            font-weight: 600;
        }
        .nav-link.level-1 {
            font-weight: 600;
            font-size: 14px;
            padding: 11px 18px;
            letter-spacing: 0.02em;
        }
        .nav-link.level-2 {
            font-size: 13px;
            padding: 7px 18px 7px 30px;
            font-weight: 400;
        }

        .nav-toggle-arrow {
            width: 16px;
            height: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 9px;
            transition: transform var(--transition);
            flex-shrink: 0;
            color: #64748b;
        }
        .nav-parent.expanded>.nav-link .nav-toggle-arrow {
            transform: rotate(90deg);
        }

        .nav-children {
            overflow: hidden;
            transition: max-height 0.35s ease;
            max-height: 0;
            padding: 0;
            margin: 0;
            list-style: none;
        }
        .nav-parent.expanded>.nav-children {
            max-height: 2600px;
        }

        /* ==================== 遮罩层 ==================== */
        .sidebar-overlay {
            display: none;
            position: fixed;
            inset: 0;
            background: rgba(15, 23, 42, 0.6);
            z-index: 999;
            opacity: 0;
            transition: opacity var(--transition);
            pointer-events: none;
        }
        .sidebar-overlay.show {
            opacity: 1;
            pointer-events: auto;
        }

        /* ==================== 主内容区 ==================== */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            min-width: 0;
            width: 100%;
            transition: margin-left var(--transition);
        }
        .main-content.expanded {
            margin-left: 0;
        }

        /* 顶部栏 */
        .top-bar {
            position: sticky;
            top: 0;
            z-index: 500;
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(10px);
            -webkit-backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--border);
            padding: 10px 20px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: var(--shadow-xs);
        }
        .hamburger-btn {
            display: none;
            background: none;
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            font-size: 18px;
            cursor: pointer;
            padding: 5px 9px;
            color: var(--text-muted);
            transition: all var(--transition);
            line-height: 1;
            flex-shrink: 0;
        }
        .hamburger-btn:hover {
            background: var(--bg-page);
            color: var(--text-heading);
            border-color: #cbd5e1;
        }
        .top-bar-title {
            font-weight: 700;
            font-size: 15px;
            color: var(--text-heading);
            white-space: nowrap;
            letter-spacing: -0.01em;
        }
        .top-bar-version {
            font-size: 11px;
            background: #eff6ff;
            color: #3b82f6;
            padding: 3px 10px;
            border-radius: 20px;
            font-weight: 600;
            white-space: nowrap;
            letter-spacing: 0.02em;
        }

        /* 内容包裹 */
        .content-wrapper {
            max-width: 960px;
            margin: 0 auto;
            padding: 32px 32px 72px 32px;
        }

        /* ==================== 章节样式 ==================== */
        .section {
            margin-bottom: 48px;
        }
        .section h1 {
            font-size: 26px;
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 8px;
            padding-bottom: 14px;
            border-bottom: 2px solid #e2e8f0;
            letter-spacing: -0.02em;
            line-height: 1.3;
        }
        .section h2 {
            font-size: 20px;
            font-weight: 700;
            color: #1e293b;
            margin-top: 36px;
            margin-bottom: 10px;
            scroll-margin-top: 80px;
            letter-spacing: -0.01em;
            line-height: 1.4;
        }
        .section h3 {
            font-size: 16px;
            font-weight: 600;
            color: #334155;
            margin-top: 24px;
            margin-bottom: 8px;
            scroll-margin-top: 80px;
            line-height: 1.4;
        }
        .section h4 {
            font-size: 14.5px;
            font-weight: 600;
            color: #475569;
            margin-top: 18px;
            margin-bottom: 6px;
            scroll-margin-top: 80px;
        }
        .section p {
            margin-bottom: 12px;
            color: var(--text-body);
            font-size: 15px;
        }
        .section ul,
        .section ol {
            margin-bottom: 14px;
            padding-left: 22px;
            color: var(--text-body);
            font-size: 15px;
        }
        .section li {
            margin-bottom: 6px;
        }
        .section strong {
            color: #0f172a;
        }

        /* 强调标签 */
        .tag {
            display: inline-block;
            padding: 1px 8px;
            border-radius: 10px;
            font-size: 11px;
            font-weight: 600;
            letter-spacing: 0.03em;
            vertical-align: middle;
            margin: 0 2px;
        }
        .tag.required {
            background: #fef2f2;
            color: #dc2626;
            border: 1px solid #fecaca;
        }
        .tag.optional {
            background: #f8fafc;
            color: #64748b;
            border: 1px solid #e2e8f0;
        }

        /* ==================== 卡片组件 ==================== */
        /* 案例卡片 */
        .case-card {
            background: var(--case-bg);
            border-left: 4px solid var(--case-border);
            border-radius: 0 var(--radius) var(--radius) 0;
            padding: 14px 18px;
            margin: 14px 0;
            font-size: 14px;
            line-height: 1.9;
            box-shadow: var(--shadow-xs);
        }
        .case-card .case-label {
            font-weight: 700;
            color: #1e40af;
            margin-bottom: 6px;
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
        .case-card code {
            background: #dbeafe;
            color: #1e40af;
            padding: 1px 6px;
            border-radius: 3px;
            font-size: 12.5px;
            font-family: var(--font-mono);
            white-space: nowrap;
        }
        .case-card .kw {
            color: #0f172a;
            font-weight: 600;
            background: #e8f0fe;
            padding: 1px 6px;
            border-radius: 3px;
            font-size: 13px;
        }
        .case-card .arrow {
            color: #3b82f6;
            margin: 0 5px;
            font-weight: 700;
        }
        .case-card .result {
            color: #059669;
            font-weight: 700;
            background: #d1fae5;
            padding: 1px 6px;
            border-radius: 3px;
            font-size: 13px;
        }

        /* 提示卡片 */
        .tip-card {
            background: var(--tip-bg);
            border-left: 4px solid var(--tip-border);
            border-radius: 0 var(--radius) var(--radius) 0;
            padding: 13px 18px;
            margin: 14px 0;
            font-size: 14px;
            box-shadow: var(--shadow-xs);
        }
        .tip-card .tip-icon {
            margin-right: 4px;
        }

        /* 对比卡片 */
        .compare-row {
            display: flex;
            gap: 12px;
            margin: 14px 0;
            flex-wrap: wrap;
        }
        .compare-item {
            flex: 1;
            min-width: 200px;
            padding: 14px 16px;
            border-radius: var(--radius);
            font-size: 13.5px;
            line-height: 1.6;
            box-shadow: var(--shadow-xs);
        }
        .compare-item.good {
            background: var(--success-bg);
            border: 1px solid #bbf7d0;
        }
        .compare-item.bad {
            background: var(--error-bg);
            border: 1px solid #fecaca;
        }
        .compare-item .label {
            font-weight: 700;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.04em;
            margin-bottom: 6px;
            display: block;
        }
        .compare-item.good .label {
            color: var(--success-text);
        }
        .compare-item.bad .label {
            color: var(--error-text);
        }

        /* ==================== 表格 ==================== */
        .table-wrapper {
            overflow-x: auto;
            margin: 16px 0;
            border-radius: var(--radius);
            border: 1px solid var(--border);
            box-shadow: var(--shadow-sm);
        }
        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            min-width: 500px;
        }
        table thead th {
            background: #f8fafc;
            color: #475569;
            font-weight: 600;
            padding: 10px 14px;
            text-align: left;
            border-bottom: 2px solid var(--border);
            white-space: nowrap;
            font-size: 12.5px;
            letter-spacing: 0.03em;
            text-transform: uppercase;
        }
        table tbody td {
            padding: 9px 14px;
            border-bottom: 1px solid var(--border-light);
            color: var(--text-body);
            vertical-align: top;
            font-size: 13.5px;
        }
        table tbody tr:hover {
            background: #fafcff;
        }
        table code {
            background: var(--code-bg);
            color: var(--code-text);
            padding: 1px 6px;
            border-radius: 3px;
            font-size: 12px;
            font-family: var(--font-mono);
            white-space: nowrap;
        }
        table .cell-highlight {
            font-weight: 600;
            color: #0f172a;
        }

        /* ==================== 代码块 ==================== */
        .code-block {
            background: #1e293b;
            color: #cbd5e1;
            padding: 14px 18px;
            border-radius: var(--radius);
            font-family: var(--font-mono);
            font-size: 13px;
            overflow-x: auto;
            margin: 14px 0;
            line-height: 1.7;
            box-shadow: var(--shadow-sm);
        }
        .code-block .hl-str {
            color: #a5d6ff;
        }
        .code-block .hl-kw {
            color: #facc15;
        }
        .code-block .hl-comment {
            color: #64748b;
        }

        /* ==================== 问答卡片 ==================== */
        .qa-card {
            background: #f8fafc;
            border-left: 4px solid #64748b;
            border-radius: 0 var(--radius) var(--radius) 0;
            padding: 14px 18px;
            margin: 10px 0;
            font-size: 14px;
            box-shadow: var(--shadow-xs);
        }
        .qa-card .qa-q {
            font-weight: 700;
            color: #0f172a;
            margin-bottom: 4px;
        }
        .qa-card .qa-a {
            color: #475569;
        }
        .qa-card code {
            background: #e2e8f0;
            color: #334155;
            padding: 1px 5px;
            border-radius: 3px;
            font-size: 12px;
            font-family: var(--font-mono);
        }

        /* ==================== 步骤编号 ==================== */
        .step-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 26px;
            height: 26px;
            border-radius: 50%;
            background: var(--accent);
            color: #fff;
            font-weight: 700;
            font-size: 12px;
            margin-right: 6px;
            flex-shrink: 0;
            box-shadow: 0 2px 6px rgba(59, 130, 246, 0.35);
        }

        /* ==================== 响应式 ==================== */
        @media (max-width: 1024px) {
            :root {
                --sidebar-width: 270px;
            }
            .content-wrapper {
                padding: 24px 20px 56px 20px;
            }
        }

        @media (max-width: 768px) {
            .sidebar {
                transform: translateX(-100%);
                width: 280px;
            }
            .sidebar.mobile-open {
                transform: translateX(0);
            }
            .sidebar-close-btn {
                display: block;
            }
            .sidebar-overlay {
                display: block;
            }
            .main-content {
                margin-left: 0 !important;
            }
            .hamburger-btn {
                display: inline-flex;
                align-items: center;
            }
            .content-wrapper {
                padding: 16px 14px 48px 14px;
            }
            .section h1 {
                font-size: 22px;
            }
            .section h2 {
                font-size: 18px;
            }
            .section h3 {
                font-size: 15px;
            }
            table {
                font-size: 12px;
            }
            table thead th,
            table tbody td {
                padding: 7px 9px;
            }
            .case-card {
                padding: 10px 14px;
                font-size: 13px;
            }
            .compare-row {
                flex-direction: column;
            }
            .compare-item {
                min-width: auto;
            }
            .code-block {
                font-size: 11px;
                padding: 10px 14px;
            }
        }
    </style>
</head>
<body>

