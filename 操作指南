    <script>
        (function() {
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            const hamburgerBtn = document.getElementById('hamburgerBtn');
            const sidebarCloseBtn = document.getElementById('sidebarCloseBtn');
            const mainContent = document.getElementById('mainContent');
            const sidebarNav = document.getElementById('sidebarNav');

            const isMobile = () => window.innerWidth <= 768;

            // 移动端打开侧边栏
            function openSidebarMobile() {
                sidebar.classList.add('mobile-open');
                sidebarOverlay.classList.add('show');
                document.body.style.overflow = 'hidden';
            }

            // 移动端关闭侧边栏
            function closeSidebarMobile() {
                sidebar.classList.remove('mobile-open');
                sidebarOverlay.classList.remove('show');
                document.body.style.overflow = '';
            }

            // 桌面端折叠/展开
            function toggleSidebarDesktop() {
                const collapsed = sidebar.classList.toggle('collapsed');
                mainContent.classList.toggle('expanded', collapsed);
            }

            // 汉堡按钮
            hamburgerBtn.addEventListener('click', () => {
                if (isMobile()) {
                    sidebar.classList.contains('mobile-open') ? closeSidebarMobile() : openSidebarMobile();
                } else {
                    toggleSidebarDesktop();
                }
            });

            // 关闭按钮
            sidebarCloseBtn.addEventListener('click', () => {
                if (isMobile()) {
                    closeSidebarMobile();
                } else {
                    toggleSidebarDesktop();
                }
            });

            // 遮罩层
            sidebarOverlay.addEventListener('click', () => {
                if (isMobile()) closeSidebarMobile();
            });

            // 窗口大小变化
            let prevWidth = window.innerWidth;
            window.addEventListener('resize', () => {
                const currWidth = window.innerWidth;
                if ((prevWidth <= 768 && currWidth > 768) || (prevWidth > 768 && currWidth <= 768)) {
                    sidebar.classList.remove('mobile-open', 'collapsed');
                    sidebarOverlay.classList.remove('show');
                    mainContent.classList.remove('expanded');
                    document.body.style.overflow = '';
                }
                prevWidth = currWidth;
            });

            // 树形导航展开/折叠
            sidebarNav.addEventListener('click', (e) => {
                const toggleEl = e.target.closest('[data-toggle]');
                if (toggleEl) {
                    e.preventDefault();
                    const parentId = toggleEl.getAttribute('data-toggle');
                    const parent = document.getElementById(parentId);
                    if (parent) {
                        parent.classList.toggle('expanded');
                    }
                }
            });

            // 导航链接点击：移动端关闭侧边栏
            sidebarNav.addEventListener('click', (e) => {
                const link = e.target.closest('a[data-section]');
                if (link && isMobile()) {
                    setTimeout(() => closeSidebarMobile(), 150);
                }
            });

            // ESC 关闭
            document.addEventListener('keydown', (e) => {
                if (e.key === 'Escape' && isMobile() && sidebar.classList.contains('mobile-open')) {
                    closeSidebarMobile();
                }
            });

            // ========== Intersection Observer：滚动高亮 ==========
            const allSectionIds = [
                'sec-1-1', 'sec-1-2', 'sec-1-3', 'sec-1-4',
                'sec-2-1', 'sec-2-2', 'sec-2-3', 'sec-2-4', 'sec-2-5',
                'sec-2-6', 'sec-2-7', 'sec-2-8', 'sec-2-9', 'sec-2-10',
                'sec-2-11', 'sec-2-12', 'sec-2-13',
                'sec-3'
            ];

            const navLinkMap = {};
            allSectionIds.forEach(id => {
                const link = sidebarNav.querySelector(`a[data-section="${id}"]`);
                if (link) navLinkMap[id] = link;
            });

            function removeAllActive() {
                sidebarNav.querySelectorAll('.nav-link.active').forEach(el => el.classList.remove('active'));
            }

            function highlightNav(id) {
                removeAllActive();
                if (navLinkMap[id]) {
                    navLinkMap[id].classList.add('active');
                }
            }

            const observer = new IntersectionObserver((entries) => {
                let visibleId = null;
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        visibleId = entry.target.id;
                    }
                });
                if (visibleId && allSectionIds.includes(visibleId)) {
                    highlightNav(visibleId);
                }
            }, {
                root: null,
                rootMargin: '-70px 0px -55% 0px',
                threshold: 0
            });

            allSectionIds.forEach(id => {
                const el = document.getElementById(id);
                if (el) observer.observe(el);
            });

            // 初始高亮
            setTimeout(() => {
                let found = false;
                for (const id of allSectionIds) {
                    const el = document.getElementById(id);
                    if (el) {
                        const rect = el.getBoundingClientRect();
                        if (rect.top >= -60 && rect.top < window.innerHeight / 2) {
                            highlightNav(id);
                            found = true;
                            break;
                        }
                    }
                }
                if (!found && allSectionIds.length > 0) {
                    highlightNav(allSectionIds[0]);
                }
            }, 300);

            console.log('✅ 西柚数据清洗打标工具 · 操作指南 v2.0 已就绪');
            console.log('   一、使用流程  |  二、打标规则  |  三、注意事项');
        })();
    </script>
